# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: openai (default) | openrouter | groq
LLM_PROVIDER=openai

# Optional: override the default model for the chosen provider
# LLM_MODEL=gpt-4.1-mini

# ── API Keys ───────────────────────────────────────────────────────────────────
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter — free key at https://openrouter.ai  (use if LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq — free key at https://console.groq.com  (use if LLM_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key_here

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8001/mcp
